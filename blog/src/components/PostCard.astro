---
import type { CollectionEntry } from 'astro:content';
import { formatDate, postUrl, UI, type Lang } from '../lib/i18n';

interface Props {
  post: CollectionEntry<'post'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, lang, heroImage, heroAlt, tags } = post.data;
const href = postUrl(lang as Lang, post.data.slug);
const ui = UI[lang as Lang];

// Rough reading-time estimate (200 wpm) — body isn't readily available at list
// time, so approximate from description length as a floor for social proof.
const minRead = Math.max(3, Math.round((description.length / 5) / 200 * 60));
---

<a href={href} class={`post-card${featured ? ' post-card--featured' : ''}`} aria-label={title}>
  <div class="post-card__cover">
    {heroImage ? (
      <img src={heroImage} alt={heroAlt ?? title} loading="lazy" decoding="async" />
    ) : (
      <div class="post-card__cover-fallback" aria-hidden="true">
        <span class="post-card__cover-mark"></span>
      </div>
    )}
    {tags?.[0] && <span class="post-card__tag">{tags[0]}</span>}
  </div>

  <div class="post-card__body">
    <p class="post-card__meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate, lang as Lang)}</time>
      <span aria-hidden="true">·</span>
      <span>{minRead} {ui.minRead}</span>
    </p>
    <h3 class="post-card__title">{title}</h3>
    <p class="post-card__excerpt">{description}</p>
    <span class="post-card__cta">
      {ui.readMore}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10m0 0L7 2m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>
