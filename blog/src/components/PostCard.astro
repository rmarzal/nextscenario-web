---
import type { CollectionEntry } from 'astro:content';
import { formatDate, postUrl, UI, type Lang } from '../lib/i18n';

interface Props {
  post: CollectionEntry<'post'>;
}

const { post } = Astro.props;
const { title, description, pubDate, lang, heroImage, heroAlt, tags } = post.data;
const href = postUrl(lang as Lang, post.data.slug);
const ui = UI[lang as Lang];
---

<article class="post-card">
  <a href={href} class="cover">
    {heroImage && <img src={heroImage} alt={heroAlt ?? title} loading="lazy" decoding="async" />}
  </a>
  <div class="meta">
    <span>{formatDate(pubDate, lang as Lang)}</span>
    {tags?.[0] && <span>{tags[0]}</span>}
  </div>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
</article>
