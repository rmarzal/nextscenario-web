---
import type { Lang } from '../lib/i18n';

type Model = 'saas' | 'ecommerce' | 'both' | 'general';

interface Props {
  lang: Lang;
  modelCounts: Record<string, number>;
  /** Active filter — `undefined` means "all". */
  currentModel?: Model;
}

const { lang, modelCounts, currentModel } = Astro.props;

const copy = {
  es: {
    all: 'Todos',
    saas: 'SaaS',
    ecommerce: 'Ecommerce',
    both: 'SaaS + Ecommerce',
    general: 'Finanzas',
  },
  en: {
    all: 'All',
    saas: 'SaaS',
    ecommerce: 'Ecommerce',
    both: 'SaaS + Ecommerce',
    general: 'Finance',
  },
} as const;

const c = copy[lang];

const listingBase = lang === 'es' ? '/es/blog-es' : '/blog';
const total = Object.values(modelCounts).reduce((a, b) => a + b, 0);

const tabs = [
  { id: 'all' as const, label: c.all, count: total, href: `${listingBase}/` },
  { id: 'saas' as const, label: c.saas, count: modelCounts.saas ?? 0, href: `${listingBase}/saas/` },
  { id: 'both' as const, label: c.both, count: modelCounts.both ?? 0, href: `${listingBase}/both/` },
  { id: 'ecommerce' as const, label: c.ecommerce, count: modelCounts.ecommerce ?? 0, href: `${listingBase}/ecommerce/` },
  { id: 'general' as const, label: c.general, count: modelCounts.general ?? 0, href: `${listingBase}/general/` },
].filter((t) => t.id === 'all' || t.count > 0);

const activeId: string = currentModel ?? 'all';
---

<nav class="category-tabs" aria-label={lang === 'es' ? 'Filtrar por categoría' : 'Filter by category'}>
  <div class="category-tabs__inner">
    {tabs.map((t) => (
      <a
        href={t.href}
        class={`category-tab category-tab--${t.id}${activeId === t.id ? ' category-tab--active' : ''}`}
        aria-current={activeId === t.id ? 'page' : undefined}
      >
        <span class="category-tab__label">{t.label}</span>
        <span class="category-tab__count">{t.count}</span>
      </a>
    ))}
  </div>
</nav>
