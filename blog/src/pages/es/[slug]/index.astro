---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTABlock from '../../../components/CTABlock.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import { formatDate, postAbsUrl, UI } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('post', ({ data }) => data.lang === 'es' && !data.draft);
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  tags,
  translationOf,
  canonical,
  author,
  businessModel,
} = post.data;

const alternates = translationOf ? [{ lang: 'en' as const, slug: translationOf }] : [];
const ui = UI.es;

const allEsPosts = await getCollection('post', ({ data }) => data.lang === 'es' && !data.draft);
const counts = allEsPosts.reduce(
  (acc, p) => ({ ...acc, [p.data.businessModel]: (acc[p.data.businessModel] ?? 0) + 1 }),
  {} as Record<string, number>
);

const modelLabels = {
  saas: 'SaaS',
  ecommerce: 'Ecommerce',
  both: 'SaaS + Ecommerce',
  general: 'Finanzas',
} as const;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author, url: 'https://nextscenario.com' },
  publisher: {
    '@type': 'Organization',
    name: 'NextScenario',
    logo: {
      '@type': 'ImageObject',
      url: 'https://nextscenario.com/og-default.png',
    },
  },
  mainEntityOfPage: postAbsUrl('es', post.data.slug),
  inLanguage: 'es',
};
---

<BaseLayout
  title={`${title} — NextScenario`}
  description={description}
  lang="es"
  canonical={canonical ?? postAbsUrl('es', post.data.slug)}
  ogImage={heroImage}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <div class="container">
    <div class="article-layout">
      <article class="article">
        <header>
          <p class="eyebrow">
            <a href="/es/blog-es/" style="color:inherit;">← {ui.backToBlog}</a>
          </p>
          <h1>{title}</h1>
          <p class="lede">{description}</p>
          <div class="meta">
            <span>{author}</span>
            <a
              href={`/es/blog-es/${businessModel}/`}
              class={`post-card__model post-card__model--${businessModel} article__model-link`}
              aria-label={`Ver más artículos de ${modelLabels[businessModel]}`}
            >
              {modelLabels[businessModel]}
            </a>
          </div>
          {tags.length > 0 && (
            <div class="tag-row">
              {tags.map((t: string) => <span class="tag-pill">{t}</span>)}
            </div>
          )}
        </header>

        {heroImage ? (
          <div class="hero-image">
            <img src={heroImage} alt={heroAlt ?? title} loading="eager" />
          </div>
        ) : (
          <div class="hero-image hero-image--fallback" aria-hidden="true">
            <div class="hero-fallback-mark">
              <span class="logo-mark"></span>
            </div>
            <div class="hero-fallback-meta">
              {tags[0] && <span class="hero-fallback-tag">{tags[0]}</span>}
              <span class="hero-fallback-brand">NextScenario</span>
            </div>
          </div>
        )}

        <div class="prose">
          <Content />
        </div>

        <CTABlock lang="es" campaign="blog_post" />
      </article>

      <BlogSidebar lang="es" modelCounts={counts} />
    </div>
  </div>

  <a class="sticky-cta" href="/es/reservar-demo.html" aria-label="Solicitar demo">
    <span class="sticky-cta__dot" aria-hidden="true"></span>
    Solicitar demo
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M2 7h10m0 0L7 2m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</BaseLayout>
