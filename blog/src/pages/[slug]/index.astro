---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import { formatDate, postAbsUrl, UI } from '../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('post', ({ data }) => data.lang === 'en' && !data.draft);
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  tags,
  translationOf,
  canonical,
  author,
} = post.data;

const alternates = translationOf ? [{ lang: 'es' as const, slug: translationOf }] : [];
const ui = UI.en;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author, url: 'https://nextscenario.com' },
  publisher: {
    '@type': 'Organization',
    name: 'NextScenario',
    logo: {
      '@type': 'ImageObject',
      url: 'https://nextscenario.com/og-default.png',
    },
  },
  mainEntityOfPage: postAbsUrl('en', post.data.slug),
  inLanguage: 'en',
};
---

<BaseLayout
  title={`${title} — NextScenario`}
  description={description}
  lang="en"
  canonical={canonical ?? postAbsUrl('en', post.data.slug)}
  ogImage={heroImage}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <article class="article">
    <div class="container">
      <header>
        <p class="eyebrow">
          <a href="/blog/" style="color:inherit;">← {ui.backToBlog}</a>
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <div class="meta">
          <span>{ui.publishedOn} {formatDate(pubDate, 'en')}</span>
          {updatedDate && <span>{ui.updatedOn} {formatDate(updatedDate, 'en')}</span>}
          <span>{author}</span>
        </div>
        {tags.length > 0 && (
          <div class="tag-row">
            {tags.map((t: string) => <span class="tag-pill">{t}</span>)}
          </div>
        )}
      </header>

      {heroImage ? (
        <div class="hero-image">
          <img src={heroImage} alt={heroAlt ?? title} loading="eager" />
        </div>
      ) : (
        <div class="hero-image hero-image--fallback" aria-hidden="true">
          <div class="hero-fallback-mark">
            <span class="logo-mark"></span>
          </div>
          <div class="hero-fallback-meta">
            {tags[0] && <span class="hero-fallback-tag">{tags[0]}</span>}
            <span class="hero-fallback-brand">NextScenario</span>
          </div>
        </div>
      )}

      <div class="prose">
        <Content />
      </div>

      <CTABlock lang="en" />
    </div>
  </article>

  <a class="sticky-cta" href="/book-demo.html" aria-label="Book a demo">
    <span class="sticky-cta__dot" aria-hidden="true"></span>
    Book a demo
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M2 7h10m0 0L7 2m5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</BaseLayout>
